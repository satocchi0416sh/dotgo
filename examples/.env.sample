# Sample environment file for dotgo templates
# Copy this file to ~/.config/dotgo/secrets/.env and fill in your values
# NEVER commit this file with actual secrets to your repository!

# Git configuration
GIT_USER_NAME="Your Name"
GIT_USER_EMAIL="your.email@example.com"
GIT_SIGNING_KEY=""  # Optional: Your GPG signing key

# Editor preferences
EDITOR="vim"
GIT_PAGER="less -FRX"

# Git workflow preferences
GIT_PULL_REBASE="false"
GIT_PUSH_DEFAULT="simple"

# Work configuration (optional)
WORK_EMAIL=""  # Set if you have a work email
WORK_GITHUB_TOKEN=""  # GitHub token for work repositories

# SSH configuration
SSH_KEY_PATH="~/.ssh/id_ed25519"
SSH_AGENT_FORWARD="yes"

# AWS configuration (optional)
AWS_REGION="us-east-1"
AWS_PROFILE="default"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# NPM configuration (optional)
NPM_TOKEN=""
NPM_REGISTRY="https://registry.npmjs.org/"

# Custom tool configurations
HOMEBREW_PREFIX="/opt/homebrew"
CARGO_HOME="~/.cargo"
RUSTUP_HOME="~/.rustup"
